#!/usr/bin/env python3
"""play-submit — opt-in AAB upload, track release, and commit via the Play edits transaction.

Dry-run by default: opens an edit to read existing state and reports intended
mutations WITHOUT executing them. Only mutates when the matching --yes flag is
passed explicitly. Each distinct mutation kind requires its own --yes:

  --yes upload      → edits.bundles.upload (upload the AAB into the open edit)
  --yes listing     → edits.listings (check listing text; guide assets via Console — Step 5)
  --yes data-safety → derive Data Safety declarations from Phase 0 + guide Console entry — Step 6
  --yes release     → edits.tracks.update (assign the bundle to the target track)
  --yes commit      → edits.commit (publish all staged mutations atomically)

Nothing is live until edits.commit. An uncommitted edit changes nothing. The
edit expires automatically if not committed; the script also discards it on
dry-run exit.

Secret hygiene (HARD): the service-account JSON contains a private key. This
script NEVER prints, logs, or writes: the JSON file contents, the private key,
the unsigned JWT assertion, or the OAuth access token. --debug emits only
non-sensitive diagnostics (request labels + HTTP status codes) to stderr.
Keystore passwords are never read or logged.

Prerequisites: Python 3 (stdlib only) + `openssl` on PATH (RS256 signing).

Usage:
    play-submit <package> --aab <path> --track <track>
                [--rollout <fraction>]
                [--yes upload] [--yes release] [--yes commit]
                [--version-code <int>]
                [--report <phase0.json>]
                [--service-account <path>]
                [--debug]
    play-submit --help

Arguments:
    package            Application ID / package name (e.g. com.example.app).
    --aab <path>       Path to the signed .aab file to upload.
    --track <track>    Target track: internal | alpha | beta | production.
                       REQUIRED with no default — "oops I shipped to prod" must
                       be structurally hard.
    --rollout <f>      Staged rollout fraction (0.0–1.0). REQUIRED when
                       --track production. Conventional first value: 0.01 (1%).
                       Recommend Internal Testing first, then promote up the
                       track ladder.
    --yes <kind>       Approve a specific mutation: upload | release | commit.
                       Each kind is a SEPARATE checkpoint, never batched.
                       Without any --yes the script is a read-only dry-run.
    --version-code <n> Expected versionCode (for collision check). Falls back
                       to the Phase 0 report's version_code field.
    --report <path>    Phase 0 situation-report JSON (optional).
    --service-account  Override path to the service-account JSON.
    --debug            Non-sensitive diagnostics to stderr (no secrets at any
                       verbosity).

Exit codes:
    0  Success (dry-run plan printed, or mutations executed as approved).
    2  Usage error (missing required arg, versionCode collision, signing blocker,
       missing credentials, or API error during execution).
"""

import argparse
import base64
import json
import os
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
import uuid

sys.dont_write_bytecode = True

API_BASE = "https://androidpublisher.googleapis.com/androidpublisher/v3"
UPLOAD_BASE = "https://androidpublisher.googleapis.com/upload/androidpublisher/v3"
TOKEN_URL = "https://oauth2.googleapis.com/token"
PUBLISHER_SCOPE = "https://www.googleapis.com/auth/androidpublisher"

# Env var NAMES whose presence hints at a Play service-account credential source.
# Only NAMES are ever surfaced — VALUES are read solely to resolve a file path
# and are never printed/logged/emitted.
_SA_ENV_VARS = (
    "ANDROID_PUBLISHER_SERVICE_ACCOUNT",
    "GOOGLE_APPLICATION_CREDENTIALS",
    "PLAY_STORE_SERVICE_ACCOUNT",
    "PLAY_CONFIG_JSON",
)

_OUT_OF_REPO_SA = "~/.config/play/play-service-account.json"

VALID_YES_FLAGS = frozenset({"upload", "release", "commit", "listing", "data-safety", "publish-iap"})
VALID_TRACKS = frozenset({"internal", "alpha", "beta", "production"})


# ---------------------------------------------------------------------------
# Pure functions (importable + unit-tested). No I/O, no global state.
# ---------------------------------------------------------------------------

def _b64url(data: bytes) -> str:
    """Base64url encode without padding."""
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def build_jwt_assertion_segments(client_email: str, scope: str, audience: str,
                                 iat: int, exp: int) -> str:
    """Build the unsigned JWS assertion (header.payload) for the Google
    service-account OAuth2 JWT flow (mirrors play-status §auth)."""
    header = {"alg": "RS256", "typ": "JWT"}
    payload = {
        "iss": client_email,
        "scope": scope,
        "aud": audience,
        "iat": iat,
        "exp": exp,
    }
    h = _b64url(json.dumps(header, separators=(",", ":")).encode("utf-8"))
    p = _b64url(json.dumps(payload, separators=(",", ":")).encode("utf-8"))
    return f"{h}.{p}"


def parse_yes_flags(yes_list: list | None) -> frozenset:
    """Parse --yes flag values into a frozenset of approved mutation kinds.

    Valid kinds: upload | release | commit. Unknown values are warned and
    ignored — they are not a usage error (forward-compat posture). Unknown
    kinds cannot unlock any mutation.
    """
    known: set = set()
    for y in (yes_list or []):
        if y in VALID_YES_FLAGS:
            known.add(y)
        else:
            print(
                f"WARNING: unknown --yes value {y!r} (ignored). "
                f"Valid values: {', '.join(sorted(VALID_YES_FLAGS))}",
                file=sys.stderr,
            )
    return frozenset(known)


def validate_args(package: str, aab: str, track: str | None,
                  rollout: float | None) -> list:
    """Validate required args. Returns a list of error strings (empty = valid).

    Hard rules (exit 2 on any):
    - package must be non-empty
    - aab must be non-empty
    - --track is required with no default
    - --rollout is required when --track production (no safe default)
    - --track must be a known track value
    """
    errors = []
    if not package:
        errors.append("package (application ID) is required")
    if not aab:
        errors.append("--aab <path> is required")
    if not track:
        errors.append(
            "--track is required (choices: internal | alpha | beta | production); "
            "there is no default — 'oops I shipped to prod' must be structurally hard"
        )
    elif track == "production" and rollout is None:
        errors.append(
            "--rollout <fraction> is required when --track production; "
            "conventional first fraction: 0.01 (1%); no safe default exists. "
            "Recommend: release to internal first, then promote to production."
        )
    elif track not in VALID_TRACKS:
        errors.append(
            f"--track {track!r} is not valid. "
            f"Valid tracks: {', '.join(sorted(VALID_TRACKS))}"
        )
    return errors


def check_version_collision(existing_codes: list, new_code: int) -> tuple:
    """Check whether new_code collides with any code on the target track.

    A versionCode must be strictly greater than every existing code on the
    target track. Equality is a collision — Play rejects it.

    Returns (collision: bool, message: str).
    """
    if not existing_codes:
        return False, f"versionCode {new_code}: no existing codes on track — no collision"
    max_existing = max(existing_codes)
    if new_code <= max_existing:
        return True, (
            f"versionCode {new_code} COLLIDES: target track already has codes "
            f"{sorted(existing_codes)} (max={max_existing}). "
            f"Increment versionCode to at least {max_existing + 1}."
        )
    return False, f"versionCode {new_code}: OK (max on track = {max_existing})"


def check_signing_from_report(report: dict) -> dict:
    """Determine signing posture from Phase 0 situation report.

    Returns a dict with:
      first_release: True = first release (Play App Signing enrolment needed),
                    False = subsequent (upload key suffices),
                    None = cannot determine from Phase 0 alone.
      blocker: True = signing not configured (hard stop before build/upload).
      message: human-readable summary (no secrets — paths and booleans only).

    Never logs or returns keystore passwords. Only paths + booleans.
    OQ4 (locked): first-release enrolment guidance inline, one-time irrevocable.
    """
    signing = report.get("signing") or {}
    configured = signing.get("signing_config_set") or bool(signing.get("keystore_hints"))
    hints = signing.get("keystore_hints") or []

    if not configured:
        return {
            "first_release": None,
            "blocker": True,
            "message": (
                "BLOCKER: signing_config_set is false and no keystore_hints detected.\n"
                "Add a signingConfig to android/app/build.gradle before building:\n"
                "  android {\n"
                "    signingConfigs {\n"
                "      release {\n"
                "        keyAlias     keystoreProperties['keyAlias']\n"
                "        keyPassword  keystoreProperties['keyPassword']   // never log\n"
                "        storeFile    file(keystoreProperties['storeFile'])\n"
                "        storePassword keystoreProperties['storePassword'] // never log\n"
                "      }\n"
                "    }\n"
                "    buildTypes { release { signingConfig signingConfigs.release } }\n"
                "  }"
            ),
        }

    enrollable = signing.get("play_app_signing_enrollable_from_repo")
    hint_path = hints[0] if hints else "(signingConfig wired)"

    if enrollable is True:
        # Phase 0 heuristic: no Play App Signing artifact detected → likely first release.
        # First-release enrolment is one-time and irrevocable (PRD §5.2, OQ4).
        return {
            "first_release": True,
            "blocker": False,
            "message": (
                f"Signing configured ({hint_path}).\n"
                "FIRST RELEASE — Play App Signing enrolment (one-time, irrevocable):\n"
                "  Step 2a: In Play Console → Setup → App signing, choose\n"
                "           'Let Google manage and protect your app signing key.'\n"
                "  Step 2b: Google re-signs APKs delivered to users with their key.\n"
                "           Your upload key only signs the AAB (can be reset if lost).\n"
                "  Step 2c: This decision cannot be undone. Confirm in Play Console\n"
                "           before running --yes upload on this first release."
            ),
        }

    return {
        "first_release": False,
        "blocker": False,
        "message": (
            f"Signing configured ({hint_path}). "
            "Subsequent release — upload key suffices (resettable via Play Console if lost)."
        ),
    }


def parse_track_existing_codes(tracks_body: dict, track: str) -> list:
    """Extract existing versionCodes for `track` from an edits.tracks response.

    Returns an empty list if the track is not found or has no releases.
    """
    for t in (tracks_body.get("tracks") or []):
        if t.get("track") == track:
            codes = []
            for release in (t.get("releases") or []):
                for vc in (release.get("versionCodes") or []):
                    try:
                        codes.append(int(vc))
                    except (TypeError, ValueError):
                        pass
            return codes
    return []


def build_edits_insert_url(package: str) -> str:
    """URL for edits.insert (POST — creates a new transactional edit)."""
    q = urllib.parse.quote(package, safe="")
    return f"{API_BASE}/applications/{q}/edits"


def build_edits_tracks_get_url(package: str, edit_id: str) -> str:
    """URL for edits.tracks.list (GET — reads all tracks within an edit)."""
    q = urllib.parse.quote(package, safe="")
    ei = urllib.parse.quote(edit_id, safe="")
    return f"{API_BASE}/applications/{q}/edits/{ei}/tracks"


def build_edits_bundles_upload_url(package: str, edit_id: str) -> str:
    """URL for edits.bundles.upload (multipart POST via upload base — uploads the AAB)."""
    q = urllib.parse.quote(package, safe="")
    ei = urllib.parse.quote(edit_id, safe="")
    return f"{UPLOAD_BASE}/applications/{q}/edits/{ei}/bundles?uploadType=multipart"


def build_edits_tracks_update_url(package: str, edit_id: str, track: str) -> str:
    """URL for edits.tracks.update (PUT — assigns bundle to track with rollout)."""
    q = urllib.parse.quote(package, safe="")
    ei = urllib.parse.quote(edit_id, safe="")
    t = urllib.parse.quote(track, safe="")
    return f"{API_BASE}/applications/{q}/edits/{ei}/tracks/{t}"


def build_edits_commit_url(package: str, edit_id: str) -> str:
    """URL for edits.commit (POST — publishes all staged mutations atomically)."""
    q = urllib.parse.quote(package, safe="")
    ei = urllib.parse.quote(edit_id, safe="")
    return f"{API_BASE}/applications/{q}/edits/{ei}:commit"


def build_edits_delete_url(package: str, edit_id: str) -> str:
    """URL for edits.delete (DELETE — discards an uncommitted edit)."""
    q = urllib.parse.quote(package, safe="")
    ei = urllib.parse.quote(edit_id, safe="")
    return f"{API_BASE}/applications/{q}/edits/{ei}"


def build_edits_listings_url(package: str, edit_id: str, language: str = "") -> str:
    """URL for edits.listings (GET all locales or PUT a single locale).

    language="":     returns the listings list URL (GET — read all locales).
    language="en-US": returns the single-locale URL (PUT — write listing text for that locale).

    Used by the --yes listing checkpoint (Step 5).
    """
    q = urllib.parse.quote(package, safe="")
    ei = urllib.parse.quote(edit_id, safe="")
    base = f"{API_BASE}/applications/{q}/edits/{ei}/listings"
    if language:
        lang = urllib.parse.quote(language, safe="")
        return f"{base}/{lang}"
    return base


def build_edits_details_url(package: str, edit_id: str) -> str:
    """URL for edits.details (GET/PUT — appDetails: Privacy Policy URL, contact email).

    appDetails fields: defaultLanguage, contactEmail, contactPhone, contactWebsite,
    privacyPolicy. This is also where Privacy Policy URL is staged for Step 8.
    Used by the --yes data-safety checkpoint (Step 6/Step 8).
    """
    q = urllib.parse.quote(package, safe="")
    ei = urllib.parse.quote(edit_id, safe="")
    return f"{API_BASE}/applications/{q}/edits/{ei}/details"


def build_inappproducts_patch_url(package: str, sku: str) -> str:
    """URL for inappproducts.patch (PATCH — activate/update a one-time IAP product, Step 10b).

    Edit-free: takes effect immediately outside the edits transaction.
    Pass `{"status": "active"}` as the request body to activate a draft product.
    """
    q = urllib.parse.quote(package, safe="")
    s = urllib.parse.quote(sku, safe="")
    return f"{API_BASE}/applications/{q}/inappproducts/{s}"


def build_subscription_baseplans_activate_url(package: str, product_id: str,
                                               base_plan_id: str) -> str:
    """URL for monetization.subscriptions.basePlans.activate (POST — Step 10b).

    Edit-free: takes effect immediately. A subscription with no active base plan
    cannot be purchased regardless of the subscription-level state
    (play-api-reference.md §5.1 / §5.2).
    """
    q = urllib.parse.quote(package, safe="")
    p = urllib.parse.quote(product_id, safe="")
    b = urllib.parse.quote(base_plan_id, safe="")
    return f"{API_BASE}/applications/{q}/subscriptions/{p}/basePlans/{b}:activate"


def build_track_release_payload(track: str, version_codes: list,
                                 rollout: float | None) -> dict:
    """Build the edits.tracks.update request body.

    Production with rollout < 1.0 → status inProgress (staged rollout).
    Other tracks or rollout == 1.0 → status completed.
    OQ3 (locked): 0.01 (1%) is the conventional first fraction; no default here —
    the caller is required to supply an explicit fraction for production.
    """
    if track == "production" and rollout is not None and rollout < 1.0:
        release: dict = {
            "versionCodes": [str(vc) for vc in version_codes],
            "status": "inProgress",
            "userFraction": rollout,
        }
    else:
        release = {
            "versionCodes": [str(vc) for vc in version_codes],
            "status": "completed",
        }
        if rollout is not None:
            release["userFraction"] = rollout
    return {"track": track, "releases": [release]}


def describe_dry_run_plan(package: str, aab_path: str, track: str,
                          rollout: float | None, version_code: int | None,
                          existing_codes: list, collision: bool,
                          collision_msg: str, yes_flags: frozenset) -> str:
    """Return a human-readable dry-run plan description (no secrets, no mutations)."""
    vc_label = (
        str(version_code) if version_code is not None
        else "? (unknown — provide --version-code or --report)"
    )
    rollout_label = (
        f"{rollout} ({int(rollout * 100)}%)" if rollout is not None else "n/a"
    )
    collision_label = f"COLLISION — {collision_msg}" if collision else f"OK — {collision_msg}"
    collision_marker = "⚠" if collision else "✓"

    stages = []
    for kind, desc in [
        (
            "upload",
            f"edits.bundles.upload — upload {aab_path!r} "
            f"(versionCode {vc_label}) into the open edit",
        ),
        (
            "release",
            f"edits.tracks.update — assign versionCode {vc_label} to track "
            f"'{track}'"
            + (f" with rollout {rollout_label}" if rollout is not None else ""),
        ),
        (
            "commit",
            "edits.commit — publish all staged mutations atomically "
            "(irreversible; staged rollout is haltable/promotable via Step 12)",
        ),
    ]:
        if kind in yes_flags:
            gate = f"APPROVED (--yes {kind} passed)"
            marker = "✓"
        else:
            gate = f"BLOCKED  (add --yes {kind} to approve)"
            marker = "□"
        stages.append(f"  {marker} {kind:8s}: {gate}\n             {desc}")

    lines = [
        "=== play-submit: dry-run plan ===",
        f"",
        f"Package     : {package}",
        f"AAB         : {aab_path}",
        f"Track       : {track}",
        f"Rollout     : {rollout_label}",
        f"versionCode : {vc_label}",
        f"Collision   : {collision_marker} {collision_label}",
        f"",
        "Mutation stages (each requires its own --yes — never batched):",
    ] + stages + [
        "",
        "Dry-run complete — edit opened to read state, NOT committed.",
        "Nothing has changed in Play Console.",
        "",
        "Tip: release to 'internal' first (instant, no review), then promote to production.",
        "     Conventional first production rollout fraction: 0.01 (1%).",
    ]
    return "\n".join(lines)


def derive_data_safety_declarations(report: dict) -> dict:
    """Derive the Data Safety declaration map from Phase 0 facts.

    Never asks the user what data the app collects. Reads Phase 0 fields:
      data_safety_hints.analytics_tracking  → crash_logs / app_interactions
      permissions.declared                  → CAMERA, LOCATION, CONTACTS, RECORD_AUDIO
      supabase_used                         → email_address, user_ids
      push_notifications.fcm_used           → device_or_other_ids (FCM registration token)
      data_safety_hints.account_deletion.likely_present → data_deletion_provided

    Returns:
      declared_data_types: list of canonical Play Data Safety data-type strings (in detection order)
      data_deletion_provided: bool (from account_deletion.likely_present — never user-supplied)
      sources: dict mapping each declared type to the Phase 0 field that triggered it
    """
    dsh = report.get("data_safety_hints") or {}
    perms = (report.get("permissions") or {}).get("declared") or []
    supabase = report.get("supabase_used") or False
    push = (report.get("push_notifications") or {}).get("fcm_used") or False
    account_deletion = (dsh.get("account_deletion") or {}).get("likely_present") or False

    declared: list = []
    sources: dict = {}

    def _add(dtype: str, source: str) -> None:
        if dtype not in declared:
            declared.append(dtype)
            sources[dtype] = source

    # Crash / diagnostic / usage data from analytics_tracking
    for entry in (dsh.get("analytics_tracking") or []):
        category = (entry.get("category") or "").lower()
        pkg = entry.get("package") or "unknown"
        if "crash" in category or "diagnostics" in category:
            _add("crash_logs", f"data_safety_hints.analytics_tracking[{pkg}]")
        if "analytics" in category or "usage" in category:
            _add("app_interactions", f"data_safety_hints.analytics_tracking[{pkg}]")

    # Supabase → standard Supabase Auth user account data
    if supabase:
        _add("email_address", "supabase_used=true (Supabase Auth)")
        _add("user_ids", "supabase_used=true (Supabase Auth)")

    # FCM push → device / other IDs (FCM registration token)
    if push:
        _add("device_or_other_ids", "push_notifications.fcm_used=true (FCM token)")

    # Permission-based data types
    perm_set = set(perms)
    if any("CAMERA" in p for p in perm_set):
        _add("photos_and_videos", "permissions.declared[CAMERA]")
    if any("ACCESS_FINE_LOCATION" in p for p in perm_set):
        _add("precise_location", "permissions.declared[ACCESS_FINE_LOCATION]")
    elif any("ACCESS_COARSE_LOCATION" in p for p in perm_set):
        _add("approximate_location", "permissions.declared[ACCESS_COARSE_LOCATION]")
    if any("READ_CONTACTS" in p or "WRITE_CONTACTS" in p for p in perm_set):
        _add("contacts", "permissions.declared[CONTACTS]")
    if any("RECORD_AUDIO" in p for p in perm_set):
        _add("audio_files", "permissions.declared[RECORD_AUDIO]")

    return {
        "declared_data_types": declared,
        "data_deletion_provided": account_deletion,
        "sources": sources,
    }


def check_listing_completeness(listings_body: dict) -> dict:
    """Check store listing text completeness from an edits.listings API response.

    Readable via API → check required text fields and classify ✓ or □.
    Not readable (empty/None body) → ? cannot-verify with Console path. Never "not done."

    Feature graphic, screenshots, and the store icon are NOT reliably API-readable →
    assets_status is always "cannot-verify" regardless of text completeness.

    Returns:
      text_status:   "complete" | "incomplete" | "cannot-verify"
      missing_text:  list of missing required text field labels (e.g. "title (en-US)")
      assets_status: always "cannot-verify" (Play Console manages these assets)
      console_path:  Play Console path for manual verification
      message:       human-readable summary suitable for printing
    """
    CONSOLE_PATH = "Grow → Store presence → Main store listing"

    if not listings_body:
        return {
            "text_status": "cannot-verify",
            "missing_text": [],
            "assets_status": "cannot-verify",
            "console_path": CONSOLE_PATH,
            "message": (
                f"? cannot-verify — listing API returned no data. "
                f"Verify at: {CONSOLE_PATH}"
            ),
        }

    listings = listings_body.get("listings") or []
    if not listings:
        return {
            "text_status": "cannot-verify",
            "missing_text": [],
            "assets_status": "cannot-verify",
            "console_path": CONSOLE_PATH,
            "message": (
                f"? cannot-verify — no listing locales returned. "
                f"Verify at: {CONSOLE_PATH}"
            ),
        }

    missing_text: list = []
    for listing in listings:
        lang = listing.get("language") or "?"
        for field in ("title", "shortDescription", "fullDescription"):
            label = f"{field} ({lang})"
            if not listing.get(field) and label not in missing_text:
                missing_text.append(label)

    if missing_text:
        text_status = "incomplete"
        text_msg = (
            f"□ Store listing text incomplete — missing: {', '.join(missing_text)}. "
            f"Fix at: {CONSOLE_PATH}"
        )
    else:
        text_status = "complete"
        text_msg = "✓ Store listing text complete across all API-readable locales."

    asset_note = (
        f"? cannot-verify feature graphic + screenshots (not reliably API-readable). "
        f"Verify at: {CONSOLE_PATH}"
    )

    return {
        "text_status": text_status,
        "missing_text": missing_text,
        "assets_status": "cannot-verify",
        "console_path": CONSOLE_PATH,
        "message": f"{text_msg} {asset_note}",
    }


def check_pricing_blocker(billing_likely_present: bool,
                           pricing_status: str | None = None) -> dict:
    """Check pricing and merchant profile status for production release.

    Merchant profile and pricing state are NOT API-readable → always ? cannot-verify
    from the API. However, when billing is detected from Phase 0, the skill surfaces
    a potential production blocker to verify before committing.

    pricing_status: "set" | "not_set" | None (cannot determine from Phase 0 / API)

    Returns:
      blocker:      True = hard production blocker (must resolve before --yes commit)
      message:      human-readable summary with the Console path
      console_path: where to verify in Play Console
    """
    CONSOLE_PATH = "Play Console → Monetize → Payments profile"

    if pricing_status == "not_set" and billing_likely_present:
        return {
            "blocker": True,
            "message": (
                "BLOCKER (production): pricing is NOT SET for app with IAP/paid content. "
                "Set pricing and ensure a merchant profile exists before committing. "
                f"Verify at: {CONSOLE_PATH}"
            ),
            "console_path": CONSOLE_PATH,
        }

    if billing_likely_present:
        return {
            "blocker": False,
            "message": (
                f"? cannot-verify — merchant profile + pricing (IAP detected in Phase 0). "
                f"A missing merchant profile or unset pricing blocks production release. "
                f"Verify at: {CONSOLE_PATH}"
            ),
            "console_path": CONSOLE_PATH,
        }

    return {
        "blocker": False,
        "message": (
            f"? cannot-verify — pricing/availability not API-readable. "
            f"Verify at: {CONSOLE_PATH}"
        ),
        "console_path": CONSOLE_PATH,
    }


def check_iap_catalog_blocker(
    iap_one_time: dict | None,
    iap_subscriptions: dict | None,
) -> dict:
    """Check the IAP catalog for Step 10b publishability blockers (pure, unit-tested).

    Accepts IAP fact dicts produced by _classify_iap_response (or the same format from
    play-status._iap_facts):
      {"marker": "✓"|"?", "products": [...], "cause": str|None}
    Each product dict carries:
      {"id": str, "publishable": bool, "status": str}  (inappproducts)
      {"id": str, "publishable": bool, "state": str, "base_plans": [...]}  (subscriptions)

    Returns:
      has_blocker:            True iff any confirmed non-publishable product detected.
      non_publishable:        list of human-readable problem strings (one per blocker).
      cannot_verify_warnings: list of cannot-verify strings (non-blocking; logged loudly).
      message:                human-readable summary for printing.

    Hard-blocker rule (Step 10b): confirmed non-publishable products block edits.commit.
    Cannot-verify entries (API error / 403) are loud warnings, not hard blockers —
    the user must verify in Play Console. PRD §10.2 Step 10b.
    """
    non_publishable: list = []
    cannot_verify_warnings: list = []

    for label, entry in [("one-time IAP", iap_one_time),
                          ("subscription", iap_subscriptions)]:
        if entry is None:
            continue
        if entry.get("marker") == "?":
            cause = entry.get("cause") or "cannot-verify"
            cannot_verify_warnings.append(
                f"{label}: ? cannot-verify ({cause}) — verify in Play Console"
            )
            continue
        for p in (entry.get("products") or []):
            if not p.get("publishable", True):
                pid = p.get("id", "?")
                if "base_plans" in p:
                    bp_active = sum(
                        1 for bp in (p.get("base_plans") or []) if bp.get("active")
                    )
                    bp_total = len(p.get("base_plans") or [])
                    state = p.get("state", "?")
                    non_publishable.append(
                        f"subscription {pid!r}: state={state}, "
                        f"{bp_active}/{bp_total} active base plan(s) — "
                        "needs at least one ACTIVE base plan to be purchasable"
                    )
                else:
                    status = p.get("status", "?")
                    non_publishable.append(
                        f"one-time IAP {pid!r}: status={status} — "
                        "must be active/published before committing"
                    )

    has_blocker = bool(non_publishable)
    if not has_blocker and not cannot_verify_warnings:
        message = "✓ IAP catalog: all products publishable — Step 10b clear."
    elif not has_blocker:
        warning_text = "; ".join(cannot_verify_warnings)
        message = f"? IAP catalog: cannot fully verify — {warning_text}"
    else:
        blockers_text = "\n  ".join(non_publishable)
        message = (
            f"⚠ STEP 10b BLOCKER — non-publishable IAP products detected:\n  {blockers_text}\n"
            "Run --yes publish-iap to publish, or resolve in Play Console before --yes commit."
        )

    return {
        "has_blocker": has_blocker,
        "non_publishable": non_publishable,
        "cannot_verify_warnings": cannot_verify_warnings,
        "message": message,
    }


def describe_iap_publish_plan(
    package: str,
    iap_one_time: dict | None,
    iap_subscriptions: dict | None,
    yes_flags: frozenset,
) -> str:
    """Return the dry-run plan for the IAP publish checkpoint (Step 10b) — pure, tested.

    Shows current IAP catalog state and whether --yes publish-iap is approved.
    Dry-run by default. iap_one_time / iap_subscriptions may be None when called
    from dry-run mode (namespaces not queried yet).
    """
    def _render_entry(label, entry):
        if entry is None:
            return f"  {label}: ? cannot-verify (not queried)"
        if entry.get("marker") == "?":
            cause = entry.get("cause") or "cannot-verify"
            return f"  {label}: ? cannot-verify ({cause})"
        products = entry.get("products") or []
        if not products:
            return f"  {label}: (no products in catalog)"
        lines = []
        for p in products:
            pid = p.get("id", "?")
            if "base_plans" in p:
                state = p.get("state", "?")
                active_bp = sum(
                    1 for bp in (p.get("base_plans") or []) if bp.get("active")
                )
                total_bp = len(p.get("base_plans") or [])
                pub = "✓ publishable" if p.get("publishable") else "□ NOT publishable"
                lines.append(
                    f"    {pid}: state={state}, "
                    f"{active_bp}/{total_bp} active base plan(s) — {pub}"
                )
            else:
                status = p.get("status", "?")
                pub = "✓ publishable" if p.get("publishable") else "□ NOT publishable"
                lines.append(f"    {pid}: status={status} — {pub}")
        return f"  {label}:\n" + "\n".join(lines)

    gate = ("APPROVED (--yes publish-iap passed)" if "publish-iap" in yes_flags
            else "BLOCKED  (add --yes publish-iap to approve)")
    marker = "✓" if "publish-iap" in yes_flags else "□"

    return "\n".join([
        "=== play-submit: IAP catalog (Step 10b) ===",
        "",
        f"Package      : {package}",
        "",
        "IAP catalog state (edit-free GETs, read-only):",
        _render_entry("One-time (inappproducts)", iap_one_time),
        _render_entry("Subscriptions (monetization.subscriptions)", iap_subscriptions),
        "",
        "IAP publish checkpoint:",
        f"  {marker} publish-iap: {gate}",
        "             Publishes draft one-time products (inappproducts.patch → active)",
        "             and activates inactive subscription base plans (basePlans.activate).",
        "             Edit-free mutations — take effect immediately, not inside the edit.",
        "",
        "HARD RULE (Step 10b): any non-publishable product blocks --yes commit.",
    ])


def describe_metadata_plan(package: str, report: dict, yes_flags: frozenset) -> str:
    """Return a human-readable dry-run plan for the metadata mutation checkpoints.

    These are separate checkpoints from the binary upload/release/commit flow:
      --yes listing:      edits.listings read/check + Console guidance for assets
      --yes data-safety:  Data Safety declaration map derived from Phase 0 facts

    Both are BLOCKED (dry-run) unless the matching --yes flag is passed explicitly.
    The Data Safety map is ALWAYS derived from Phase 0 facts — never from user input.
    """
    declarations = derive_data_safety_declarations(report)
    data_types = declarations["declared_data_types"]
    data_types_label = ", ".join(data_types) if data_types else "(none detected)"
    deletion_label = "YES" if declarations["data_deletion_provided"] else "NO"

    stages = []
    for kind, desc in [
        (
            "listing",
            "edits.listings — read listing text completeness via API; "
            "feature graphic + screenshots are ? cannot-verify (Console-only assets). "
            "Console path: Grow → Store presence → Main store listing",
        ),
        (
            "data-safety",
            f"Data Safety declarations derived from Phase 0 (not from user input): "
            f"[{data_types_label}]; data_deletion_provided={deletion_label}. "
            "Enter these values in Play Console → Policy → Data Safety.",
        ),
    ]:
        if kind in yes_flags:
            gate = f"APPROVED (--yes {kind} passed)"
            marker = "✓"
        else:
            gate = f"BLOCKED  (add --yes {kind} to approve)"
            marker = "□"
        stages.append(f"  {marker} {kind:12s}: {gate}\n               {desc}")

    lines = [
        "=== play-submit: metadata plan (Steps 5–9) ===",
        "",
        f"Package      : {package}",
        "",
        "Data Safety declarations (derived from Phase 0 — never from user input):",
        f"  Data types : {data_types_label}",
        f"  Data deletion provided: {deletion_label}",
        "",
        "Metadata checkpoints (each requires its own --yes — dry-run by default):",
    ] + stages + [
        "",
        "Note: listing assets (feature graphic, screenshots) are always ? cannot-verify",
        "      from the API — verify in Play Console, never infer 'not done' from API silence.",
        "Note: Data Safety published state is ? cannot-verify — confirm in Play Console",
        "      after entering the declarations.",
    ]
    return "\n".join(lines)


def format_status_note_entry(timestamp: str, step_id: str, details: str) -> str:
    """Format an append-only status note entry. Never contains secrets.

    Status note holds only step ids, version strings, track names, fractions,
    and timestamps — never keystore passwords, service-account JSON, or tokens.
    Raises ValueError if any known secret marker is detected in the content.
    """
    secret_markers = (
        "BEGIN RSA PRIVATE KEY", "BEGIN PRIVATE KEY",
        "private_key", "client_secret", "access_token",
        "storePassword", "keyPassword", "keyAliasPassword",
    )
    combined = f"{step_id} {details}"
    for marker in secret_markers:
        if marker.lower() in combined.lower():
            raise ValueError(
                f"status note entry contains secret marker {marker!r}; "
                "the status note must never hold credentials."
            )
    return f"{timestamp} {step_id} — {details}"


def verify_commit_result(tracks_body: dict, track: str,
                         expected_version_code: int) -> dict:
    """Verify the committed release by re-reading the target track.

    Returns {"ok": bool, "status": str|None, "message": str}.
    Never trusts the commit response alone — always re-reads the track
    (PRD §10.2 Step 11).
    """
    for t in (tracks_body.get("tracks") or []):
        if t.get("track") != track:
            continue
        for release in (t.get("releases") or []):
            try:
                vcs = [int(v) for v in (release.get("versionCodes") or [])]
            except (TypeError, ValueError):
                vcs = []
            if expected_version_code in vcs:
                status = release.get("status")
                frac = release.get("userFraction")
                frac_label = f" (rollout {int(frac * 100)}%)" if frac else ""
                return {
                    "ok": True,
                    "status": status,
                    "message": (
                        f"✓ versionCode {expected_version_code} confirmed on track "
                        f"'{track}' — status: {status}{frac_label}"
                    ),
                }

    all_codes = parse_track_existing_codes(tracks_body, track)
    return {
        "ok": False,
        "status": None,
        "message": (
            f"⚠ versionCode {expected_version_code} NOT found on track '{track}' "
            f"after commit. Present codes: {sorted(all_codes)}. "
            "Verify manually in Play Console → Release → dashboard."
        ),
    }


def classify_http(status: int, body: object) -> dict:
    """Tri-state classifier for a Play Developer API response (mirrors play-status)."""
    if status == 200:
        return {"marker": "✓", "likely_cause": None}
    causes = {
        401: "token mint failed or service-account JSON invalid",
        403: "wrong scope or service account not linked in Play Console",
        404: "app not found / package name mismatch / Play Developer API not enabled",
    }
    if status in causes:
        return {"marker": "?", "likely_cause": causes[status]}
    if status == 0:
        return {"marker": "?", "likely_cause": "network/transport error"}
    return {"marker": "?", "likely_cause": f"HTTP {status}"}


def discover_service_account(report: dict, env: dict) -> dict:
    """Pure credential discovery from Phase 0 report + env. Env var NAMES only."""
    sa_list = ((report.get("credentials") or {}).get("service_account_json")) or []
    path = None
    if sa_list and sa_list[0].get("path"):
        path = sa_list[0]["path"]
    env_names = [name for name in _SA_ENV_VARS if env.get(name)]
    if path or env_names:
        missing_cause = None
    else:
        missing_cause = (
            "no service-account JSON path in the Phase 0 report and no known "
            "Play service-account env var set"
        )
    return {"path": path, "env_names": env_names, "missing_cause": missing_cause}


# ---------------------------------------------------------------------------
# Thin wrappers (NOT unit-tested — touch the network / openssl / the key).
# ---------------------------------------------------------------------------

def sign_rs256(signing_input: bytes, private_key_pem: bytes) -> bytes:
    """RS256-sign via openssl. Key is fed on stdin — never written to disk."""
    with tempfile.NamedTemporaryFile(prefix="play-submit-jwt-", delete=True) as tf:
        tf.write(signing_input)
        tf.flush()
        proc = subprocess.run(
            ["openssl", "dgst", "-sha256", "-sign", "/dev/stdin", tf.name],
            input=private_key_pem,
            capture_output=True,
        )
    if proc.returncode != 0:
        raise RuntimeError(
            f"openssl RS256 signing failed (exit {proc.returncode}); "
            "is openssl on PATH?"
        )
    return proc.stdout


def mint_access_token(client_email: str, private_key_pem: bytes,
                      scope: str = PUBLISHER_SCOPE,
                      audience: str = TOKEN_URL) -> tuple:
    """Mint a Google OAuth2 access token. Returns (status, token|None). Never logs."""
    now = int(time.time())
    signing_input = build_jwt_assertion_segments(
        client_email, scope, audience, now, now + 3600
    ).encode("ascii")
    signature = sign_rs256(signing_input, private_key_pem)
    assertion = signing_input.decode("ascii") + "." + _b64url(signature)
    body = urllib.parse.urlencode({
        "grant_type": "urn:ietf:params:oauth:grant-type:jwt-bearer",
        "assertion": assertion,
    }).encode("ascii")
    req = urllib.request.Request(
        TOKEN_URL, data=body, method="POST",
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            payload = json.loads(r.read().decode("utf-8"))
            return r.status, payload.get("access_token")
    except urllib.error.HTTPError as e:
        return e.code, None
    except urllib.error.URLError:
        return 0, None


def http_get(url: str, token: str, debug: bool = False,
             label: str = "") -> tuple:
    """GET url with bearer token. Auth header never logged."""
    req = urllib.request.Request(
        url, method="GET",
        headers={"Authorization": f"Bearer {token}", "Accept": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            txt = r.read().decode("utf-8", errors="replace")
            if debug:
                print(f"{label}: HTTP {r.status}", file=sys.stderr)
            try:
                return r.status, json.loads(txt) if txt else {}
            except json.JSONDecodeError:
                return r.status, {}
    except urllib.error.HTTPError as e:
        if debug:
            print(f"{label}: HTTP {e.code}", file=sys.stderr)
        return e.code, {}
    except urllib.error.URLError:
        if debug:
            print(f"{label}: network error", file=sys.stderr)
        return 0, {}


def http_post_json(url: str, token: str, body: dict,
                   debug: bool = False, label: str = "") -> tuple:
    """POST JSON to url. Auth header never logged."""
    data = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        url, data=data, method="POST",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
            "Accept": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            txt = r.read().decode("utf-8", errors="replace")
            if debug:
                print(f"{label}: HTTP {r.status}", file=sys.stderr)
            try:
                return r.status, json.loads(txt) if txt else {}
            except json.JSONDecodeError:
                return r.status, {}
    except urllib.error.HTTPError as e:
        body_txt = e.read().decode("utf-8", errors="replace") if e.fp else ""
        if debug:
            print(f"{label}: HTTP {e.code}", file=sys.stderr)
        try:
            return e.code, json.loads(body_txt) if body_txt else {}
        except json.JSONDecodeError:
            return e.code, {}
    except urllib.error.URLError:
        if debug:
            print(f"{label}: network error", file=sys.stderr)
        return 0, {}


