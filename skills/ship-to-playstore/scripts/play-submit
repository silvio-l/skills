        if debug:
            print(f"{label}: network error", file=sys.stderr)
        return 0, {}


def http_patch_json(url: str, token: str, body: dict,
                    debug: bool = False, label: str = "") -> tuple:
    """PATCH JSON to url. Auth header never logged. Used by IAP publish (Step 10b)."""
    data = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        url, data=data, method="PATCH",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
            "Accept": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            txt = r.read().decode("utf-8", errors="replace")
            if debug:
                print(f"{label}: HTTP {r.status}", file=sys.stderr)
            try:
                return r.status, json.loads(txt) if txt else {}
            except json.JSONDecodeError:
                return r.status, {}
    except urllib.error.HTTPError as e:
        body_txt = e.read().decode("utf-8", errors="replace") if e.fp else ""
        if debug:
            print(f"{label}: HTTP {e.code}", file=sys.stderr)
        try:
            return e.code, json.loads(body_txt) if body_txt else {}
        except json.JSONDecodeError:
            return e.code, {}
    except urllib.error.URLError:
        if debug:
            print(f"{label}: network error", file=sys.stderr)
        return 0, {}


def upload_aab_multipart(url: str, token: str, aab_path: str,
                          debug: bool = False) -> tuple:
    """Multipart upload of the AAB file (uploadType=multipart). Token never logged."""
    boundary = uuid.uuid4().hex
    with open(aab_path, "rb") as fh:
        aab_data = fh.read()
    parts = [
        f"--{boundary}\r\n".encode(),
        b"Content-Type: application/json; charset=UTF-8\r\n\r\n{}\r\n",
        f"--{boundary}\r\n".encode(),
        b"Content-Type: application/octet-stream\r\n\r\n",
        aab_data,
        b"\r\n",
        f"--{boundary}--\r\n".encode(),
    ]
    body = b"".join(parts)
    req = urllib.request.Request(
        url, data=body, method="POST",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": f"multipart/related; boundary={boundary}",
            "Accept": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=300) as r:
            txt = r.read().decode("utf-8", errors="replace")
            if debug:
                print(f"bundles.upload: HTTP {r.status}", file=sys.stderr)
            try:
                return r.status, json.loads(txt) if txt else {}
            except json.JSONDecodeError:
                return r.status, {}
    except urllib.error.HTTPError as e:
        body_txt = e.read().decode("utf-8", errors="replace") if e.fp else ""
        if debug:
            print(f"bundles.upload: HTTP {e.code}", file=sys.stderr)
        try:
            return e.code, json.loads(body_txt) if body_txt else {}
        except json.JSONDecodeError:
            return e.code, {}
    except urllib.error.URLError:
        if debug:
            print("bundles.upload: network error", file=sys.stderr)
        return 0, {}


def _load_service_account_json(path: str) -> tuple:
    """Read SA JSON; return (client_email, private_key_pem). Contents never logged."""
    with open(path, encoding="utf-8") as fh:
        data = json.load(fh)
    client_email = data.get("client_email")
    private_key = data.get("private_key")
    if not client_email or not private_key:
        raise ValueError(
            "service-account JSON missing client_email or private_key — "
            "is this a service-account key (not an API key)?"
        )
    return client_email, private_key.encode("utf-8")


def _resolve_sa_from_env() -> str | None:
    """Resolve SA path from GOOGLE_APPLICATION_CREDENTIALS / PLAY_CONFIG_JSON. Value never printed."""
    val = os.environ.get("GOOGLE_APPLICATION_CREDENTIALS")
    if val and os.path.isfile(val):
        return val
    val = os.environ.get("PLAY_CONFIG_JSON")
    if val and os.path.isfile(val):
        return val
    return None


def _classify_iap_item(item: dict, kind: str) -> dict:
    """Classify a single IAP product from a Play API response body (mirrors play-status.classify_iap_product).

    Returns {"id", "publishable", "status"|"state", optionally "base_plans", "has_active_base_plan"}.
    Not unit-tested here — the pure check_iap_catalog_blocker covers observable behaviour.
    """
    if kind == "inappproducts":
        pid = item.get("sku") or item.get("productId") or "?"
        status = item.get("status") or "?"
        publishable = status.lower() in ("active", "published")
        return {"id": pid, "status": status, "publishable": publishable}
    # subscriptions (monetization.subscriptions namespace)
    pid = item.get("productId") or "?"
    state = item.get("state") or "?"
    bps = []
    for bp in (item.get("basePlans") or []):
        bp_state = bp.get("state") or "?"
        bps.append({
            "id": bp.get("basePlanId") or "?",
            "state": bp_state,
            "active": bp_state.upper() == "ACTIVE",
            "offers_count": len(bp.get("offers") or []),
        })
    has_active = any(b["active"] for b in bps)
    publishable = state.upper() == "ACTIVE" and has_active
    return {
        "id": pid,
        "state": state,
        "publishable": publishable,
        "base_plans": bps,
        "has_active_base_plan": has_active,
    }


def _classify_iap_response(http_status: int, body: dict, kind: str) -> dict:
    """Wrap a Play API IAP namespace GET response into the fact dict consumed by
    check_iap_catalog_blocker and describe_iap_publish_plan.
    """
    verdict = classify_http(http_status, body)
    if verdict["marker"] == "✓":
        items = body.get(kind, []) or []
        products = [_classify_iap_item(it, kind) for it in items]
        has_blocker = any(not p.get("publishable", True) for p in products)
        return {"marker": "✓", "products": products, "has_blocker": has_blocker, "cause": None}
    return {"marker": "?", "products": [], "has_blocker": False, "cause": verdict["likely_cause"]}


def _discard_edit(package: str, edit_id: str, token: str, debug: bool) -> None:
    """Discard an uncommitted edit (DELETE). Non-fatal on error (edit auto-expires)."""
    if not edit_id:
        return
    url = build_edits_delete_url(package, edit_id)
    req = urllib.request.Request(
        url, method="DELETE",
        headers={"Authorization": f"Bearer {token}"},
    )
    try:
        with urllib.request.urlopen(req, timeout=10):
            if debug:
                print("edit: discarded (DELETE)", file=sys.stderr)
    except (urllib.error.URLError, urllib.error.HTTPError):
        if debug:
            print("edit: discard failed (non-fatal; edit expires automatically)", file=sys.stderr)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main(argv: list | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="play-submit",
        description=(
            "Opt-in AAB upload, track release, and commit via the Play edits "
            "transaction. Dry-run by default — mutates only on explicit --yes."
        ),
    )
    parser.add_argument("package", help="Application ID / package name.")
    parser.add_argument("--aab", required=True, help="Path to the signed .aab file.")
    parser.add_argument(
        "--track", required=True,
        help="Target track: internal | alpha | beta | production. Required, no default.",
    )
    parser.add_argument(
        "--rollout", type=float, default=None,
        help="Staged rollout fraction 0.0-1.0. Required for --track production. "
             "Conventional first value: 0.01 = 1%%. Recommend internal first.",
    )
    parser.add_argument(
        "--yes", action="append", dest="yes", metavar="KIND",
        help="Approve a mutation: upload | release | commit. Repeat per kind. "
             "Without any --yes, dry-run only.",
    )
    parser.add_argument(
        "--version-code", dest="version_code", type=int, default=None,
        help="Expected versionCode for collision check. "
             "Falls back to Phase 0 report's version_code field.",
    )
    parser.add_argument("--report", help="Phase 0 situation-report JSON path.")
    parser.add_argument(
        "--service-account", dest="service_account",
        help="Override path to the service-account JSON.",
    )
    parser.add_argument(
        "--debug", action="store_true",
        help="Non-sensitive diagnostics to stderr (no secrets logged).",
    )
    args = parser.parse_args(argv)

    # --- Validate required args (exit 2 on any error) ---
    errors = validate_args(args.package, args.aab, args.track, args.rollout)
    if errors:
        for e in errors:
            print(f"ERROR: {e}", file=sys.stderr)
        return 2

    yes_flags = parse_yes_flags(args.yes or [])

    # --- Load Phase 0 report (optional; used for signing check + versionCode) ---
    report: dict = {}
    if args.report:
        try:
            with open(args.report, encoding="utf-8") as fh:
                report = json.load(fh)
        except (OSError, json.JSONDecodeError) as exc:
            print(f"WARNING: could not read Phase 0 report: {exc}", file=sys.stderr)

    # --- Signing check (blocker before any network call) ---
    signing_check = check_signing_from_report(report)
    if signing_check["blocker"]:
        print(signing_check["message"], file=sys.stderr)
        return 2
    print(f"Signing: {signing_check['message']}")

    # --- Resolve versionCode for collision check ---
    version_code = args.version_code if args.version_code is not None else report.get("version_code")

    # --- Discover service account ---
    discovery = discover_service_account(report, dict(os.environ))
    resolved_sa = args.service_account or discovery["path"] or _resolve_sa_from_env()
    if resolved_sa is None:
        fallback = os.path.expanduser(_OUT_OF_REPO_SA)
        if os.path.isfile(fallback):
            resolved_sa = fallback

    if resolved_sa is None:
        cause = discovery["missing_cause"] or "service-account JSON not found"
        print(f"ERROR: {cause}", file=sys.stderr)
        print(
            "Provide a service-account JSON via:\n"
            "  --service-account <path>\n"
            "  GOOGLE_APPLICATION_CREDENTIALS env var (path to the JSON file)\n"
            f"  {_OUT_OF_REPO_SA}\n"
            "  In-repo: android/api/play-service-account.json (gitignored)",
            file=sys.stderr,
        )
        return 2

    try:
        client_email, private_key_pem = _load_service_account_json(resolved_sa)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        print(f"ERROR: service-account JSON unreadable: {exc}", file=sys.stderr)
        return 2

    token_status, token = mint_access_token(client_email, private_key_pem)
    if token_status != 200 or not token:
        cause = classify_http(token_status, {})["likely_cause"]
        print(f"ERROR: token mint failed: {cause}", file=sys.stderr)
        return 2

    # --- Open edit (needed to read existing track state) ---
    ins_status, ins_body = http_post_json(
        build_edits_insert_url(args.package), token, {}, args.debug, "edits.insert"
    )
    if ins_status != 200:
        cause = classify_http(ins_status, ins_body)["likely_cause"]
        print(f"ERROR: edits.insert failed: {cause} (HTTP {ins_status})", file=sys.stderr)
        return 2

    edit_id = ins_body.get("id")
    if not edit_id:
        print("ERROR: edits.insert response missing 'id'", file=sys.stderr)
        return 2

    # --- Read existing track state + versionCode collision check ---
    tr_status, tr_body = http_get(
        build_edits_tracks_get_url(args.package, edit_id),
        token, args.debug, "edits.tracks.list",
    )
    existing_codes: list = []
    collision = False
    collision_msg = "? cannot-verify (could not read existing track state)"

    if tr_status == 200 and version_code is not None:
        existing_codes = parse_track_existing_codes(tr_body, args.track)
        collision, collision_msg = check_version_collision(existing_codes, version_code)
    elif version_code is None:
        collision_msg = (
            "? cannot-verify (no versionCode known — provide --version-code or --report)"
        )
    else:
        cause = classify_http(tr_status, tr_body)["likely_cause"]
        collision_msg = f"? cannot-verify ({cause})"

    if collision:
        print(f"ERROR: {collision_msg}", file=sys.stderr)
        _discard_edit(args.package, edit_id, token, args.debug)
        return 2

    # --- Dry-run: describe plan and exit if no --yes flags ---
    if not yes_flags:
        plan = describe_dry_run_plan(
            args.package, args.aab, args.track, args.rollout,
            version_code, existing_codes, collision, collision_msg, yes_flags,
        )
        print(plan)
        print()
        metadata_plan = describe_metadata_plan(args.package, report, yes_flags)
        print(metadata_plan)
        billing_likely = bool((report.get("play_billing") or {}).get("likely_present"))
        if billing_likely:
            print()
            # Dry-run: IAP namespaces not queried yet — show plan skeleton only
            print(describe_iap_publish_plan(args.package, None, None, yes_flags))
        _discard_edit(args.package, edit_id, token, args.debug)
        return 0

    # --- Execute approved mutations in order ---
    uploaded_vc = version_code  # may be overridden by the actual upload response

    # IAP publish checkpoint (Step 10b) — edit-free; runs before upload/release/commit
    if "publish-iap" in yes_flags:
        pkg_q = urllib.parse.quote(args.package, safe="")
        ot_s, ot_b = http_get(
            f"{API_BASE}/applications/{pkg_q}/inappproducts",
            token, args.debug, "iap.inappproducts",
        )
        sub_s, sub_b = http_get(
            f"{API_BASE}/applications/{pkg_q}/subscriptions",
            token, args.debug, "iap.subscriptions",
        )
        iap_ot = _classify_iap_response(ot_s, ot_b, "inappproducts")
        iap_sub = _classify_iap_response(sub_s, sub_b, "subscriptions")
        print(describe_iap_publish_plan(args.package, iap_ot, iap_sub, yes_flags))

        # Publish non-publishable one-time products
        if iap_ot.get("marker") == "✓":
            for p in (iap_ot.get("products") or []):
                if not p.get("publishable", True):
                    pid = p.get("id", "?")
                    print(f"Publishing one-time IAP {pid!r}…")
                    p_status, p_body = http_patch_json(
                        build_inappproducts_patch_url(args.package, pid),
                        token, {"status": "active"}, args.debug,
                        f"inappproducts.patch({pid})",
                    )
                    if p_status == 200:
                        print(f"  ✓ {pid!r}: published (status → active).")
                    else:
                        cause = classify_http(p_status, p_body)["likely_cause"]
                        print(
                            f"  ⚠ {pid!r}: publish failed — {cause} (HTTP {p_status}). "
                            "Resolve in Play Console before committing.",
                            file=sys.stderr,
                        )

        # Activate inactive subscription base plans
        if iap_sub.get("marker") == "✓":
            for p in (iap_sub.get("products") or []):
                if not p.get("publishable", True):
                    pid = p.get("id", "?")
                    for bp in (p.get("base_plans") or []):
                        if not bp.get("active"):
                            bp_id = bp.get("id", "?")
                            print(f"Activating subscription {pid!r} base plan {bp_id!r}…")
                            a_status, a_body = http_post_json(
                                build_subscription_baseplans_activate_url(
                                    args.package, pid, bp_id
                                ),
                                token, {}, args.debug,
                                f"basePlans.activate({pid}/{bp_id})",
                            )
                            if a_status == 200:
                                print(f"  ✓ {pid!r}/{bp_id!r}: base plan activated.")
                            else:
                                cause = classify_http(a_status, a_body)["likely_cause"]
                                print(
                                    f"  ⚠ {pid!r}/{bp_id!r}: activation failed — "
                                    f"{cause} (HTTP {a_status}). Resolve in Play Console.",
                                    file=sys.stderr,
                                )
    else:
        print("  [publish-iap]: SKIPPED — add --yes publish-iap to approve IAP publish (Step 10b)")

    # Mutation 1 — Upload
    if "upload" in yes_flags:
        if not os.path.isfile(args.aab):
            print(f"ERROR: AAB file not found: {args.aab!r}", file=sys.stderr)
            _discard_edit(args.package, edit_id, token, args.debug)
            return 2
        print(f"Uploading {args.aab!r} (bundles.upload)…")
        up_status, up_body = upload_aab_multipart(
            build_edits_bundles_upload_url(args.package, edit_id),
            token, args.aab, args.debug,
        )
        if up_status != 200:
            cause = classify_http(up_status, up_body)["likely_cause"]
            print(f"ERROR: bundles.upload failed: {cause} (HTTP {up_status})", file=sys.stderr)
            _discard_edit(args.package, edit_id, token, args.debug)
            return 2
        raw_vc = up_body.get("versionCode")
        if raw_vc is not None:
            uploaded_vc = int(raw_vc)
        print(f"Upload complete. versionCode: {uploaded_vc}")
    else:
        print("  [upload]: SKIPPED — add --yes upload to approve")

    # Metadata checkpoint — Listing (Step 5: store listing text check + asset guidance)
    if "listing" in yes_flags:
        print("Checking store listing completeness (edits.listings)…")
        list_status, list_body = http_get(
            build_edits_listings_url(args.package, edit_id),
            token, args.debug, "edits.listings",
        )
        if list_status == 200:
            listing_result = check_listing_completeness(list_body)
        else:
            listing_result = check_listing_completeness({})
        print(f"Listing: {listing_result['message']}")
        if listing_result["text_status"] == "incomplete":
            print(
                f"  Action: complete the missing listing fields at: {listing_result['console_path']}",
                file=sys.stderr,
            )
    else:
        print("  [listing   ]: SKIPPED — add --yes listing to approve store listing check")

    # Metadata checkpoint — Data Safety (Step 6: derive + stage declarations from Phase 0)
    if "data-safety" in yes_flags:
        print("Deriving Data Safety declarations from Phase 0 report (not from user input)…")
        declarations = derive_data_safety_declarations(report)
        data_types = declarations["declared_data_types"] or ["(none detected)"]
        deletion_label = "YES" if declarations["data_deletion_provided"] else "NO"
        print("Data Safety (Phase 0 derived):")
        print(f"  Declared data types  : {', '.join(data_types)}")
        print(f"  Data deletion provided: {deletion_label}")
        print("  Action: enter these values in Play Console → Policy → Data Safety.")
        print("  Note: Data Safety published state is ? cannot-verify via API. Confirm in Console.")
        if declarations["data_deletion_provided"]:
            print(
                "  OQ5: account deletion endpoint required. Default: Supabase Postgres function "
                "(not Edge Function) exposed via /rest/v1/rpc/delete_account. "
                "Register the URL in Play Console → Data Safety → Account deletion section."
            )
    else:
        print("  [data-safety]: SKIPPED — add --yes data-safety to approve Data Safety review")

    # Mutation 2 — Release to track
    if "release" in yes_flags:
        if "upload" not in yes_flags:
            print(
                "WARNING: --yes release without --yes upload — edit has no uploaded bundle; "
                "this may fail or commit a stale bundle.",
                file=sys.stderr,
            )
        if uploaded_vc is None:
            print(
                "ERROR: cannot release — versionCode unknown. "
                "Run with --yes upload first, or provide --version-code.",
                file=sys.stderr,
            )
            _discard_edit(args.package, edit_id, token, args.debug)
            return 2
        payload = build_track_release_payload(args.track, [uploaded_vc], args.rollout)
        tr_up_status, tr_up_body = http_put_json(
            build_edits_tracks_update_url(args.package, edit_id, args.track),
            token, payload, args.debug, "edits.tracks.update",
        )
        if tr_up_status != 200:
            cause = classify_http(tr_up_status, tr_up_body)["likely_cause"]
            print(
                f"ERROR: edits.tracks.update failed: {cause} (HTTP {tr_up_status})",
                file=sys.stderr,
            )
            _discard_edit(args.package, edit_id, token, args.debug)
            return 2
        print(f"Track '{args.track}' updated with versionCode {uploaded_vc}")
    else:
        print("  [release]: SKIPPED — add --yes release to approve")

    # Mutation 3 — Commit
    if "commit" in yes_flags:
        if "release" not in yes_flags:
            print(
                "WARNING: --yes commit without --yes release — committing without a "
                "track update; this may publish a stale state.",
                file=sys.stderr,
            )

        # Step 10b HARD BLOCKER — verify IAP catalog before committing (PRD §10.2 Step 10b)
        billing_likely = bool((report.get("play_billing") or {}).get("likely_present"))
        if billing_likely:
            pkg_q = urllib.parse.quote(args.package, safe="")
            ot_s, ot_b = http_get(
                f"{API_BASE}/applications/{pkg_q}/inappproducts",
                token, args.debug, "step10b.inappproducts",
            )
            sub_s, sub_b = http_get(
                f"{API_BASE}/applications/{pkg_q}/subscriptions",
                token, args.debug, "step10b.subscriptions",
            )
            iap_blocker = check_iap_catalog_blocker(
                _classify_iap_response(ot_s, ot_b, "inappproducts"),
                _classify_iap_response(sub_s, sub_b, "subscriptions"),
            )
            if iap_blocker["has_blocker"]:
                print(
                    "\n⚠ STEP 10b HARD BLOCKER — IAP catalog blocks commit:",
                    file=sys.stderr,
                )
                print(iap_blocker["message"], file=sys.stderr)
                _discard_edit(args.package, edit_id, token, args.debug)
                return 2
            for w in (iap_blocker.get("cannot_verify_warnings") or []):
                print(f"  ⚠ Step 10b warning: {w}", file=sys.stderr)
            print(iap_blocker["message"])

        print("Committing edit (edits.commit — publishes to Play Console)…")
        cm_status, cm_body = http_post_json(
            build_edits_commit_url(args.package, edit_id),
            token, {}, args.debug, "edits.commit",
        )
        if cm_status != 200:
            cause = classify_http(cm_status, cm_body)["likely_cause"]
            print(f"ERROR: edits.commit failed: {cause} (HTTP {cm_status})", file=sys.stderr)
            return 2
        print("Edit committed.")

        # Post-commit verification: open a fresh read-only edit to re-read tracks.
        if uploaded_vc is not None:
            print("Verifying via tracks re-read…")
            ver_ins_status, ver_ins_body = http_post_json(
                build_edits_insert_url(args.package),
                token, {}, args.debug, "verify.edits.insert",
            )
            if ver_ins_status == 200:
                ver_edit_id = ver_ins_body.get("id", "")
                ver_tr_status, ver_tr_body = http_get(
                    build_edits_tracks_get_url(args.package, ver_edit_id),
                    token, args.debug, "verify.tracks.list",
                )
                if ver_tr_status == 200:
                    result = verify_commit_result(ver_tr_body, args.track, uploaded_vc)
                    print(result["message"])
                    if not result["ok"]:
                        print(
                            "Verify inconclusive — confirm in Play Console > Release.",
                            file=sys.stderr,
                        )
                else:
                    print(
                        f"? cannot-verify post-commit (tracks read HTTP {ver_tr_status}); "
                        "confirm in Play Console.",
                        file=sys.stderr,
                    )
                _discard_edit(args.package, ver_edit_id, token, args.debug)
            else:
                print(
                    "? cannot-verify post-commit (could not open verification edit); "
                    "confirm in Play Console.",
                    file=sys.stderr,
                )
    else:
        print(
            f"  [commit]: SKIPPED — add --yes commit to approve. "
            f"Edit NOT committed; nothing is live in Play Console."
        )
        _discard_edit(args.package, edit_id, token, args.debug)

    return 0


if __name__ == "__main__":
    sys.exit(main())
