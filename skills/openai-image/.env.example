# API-key schema. The script reads OPENAI_API_KEY in this order:
#   shell env  →  ~/.config/openai-image/.env  →  <skill>/.env  →  ./.env
# Prefer ~/.config/openai-image/.env — it lives outside the skill folder, so
# `skills update` (which wipes and re-writes the skill dir) never deletes it.
#   mkdir -p ~/.config/openai-image
#   printf 'OPENAI_API_KEY=sk-...\n' > ~/.config/openai-image/.env
OPENAI_API_KEY=sk-your-key-here
