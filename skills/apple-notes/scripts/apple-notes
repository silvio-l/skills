#!/usr/bin/env bash
# apple-notes — Claude Code skill dispatcher for Apple Notes on macOS.
#
# Subcommands: projects, resolve, notes, get, images, search,
#              create, update, append, delete, move, config.
#
# All AppleScript invocations pass arguments via osascript's argv —
# no shell-level string interpolation, no quoting bugs, safe for
# Unicode titles and bodies of arbitrary size.

set -euo pipefail

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HELPER="$SKILL_DIR/scripts/_helper.py"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude/apple-notes"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude/apple-notes"
CONFIG_FILE="$CONFIG_DIR/config.json"
MAPPING_FILE="$CONFIG_DIR/mapping.json"

mkdir -p "$CONFIG_DIR" "$CACHE_DIR"
[ -f "$CONFIG_FILE" ] || cat > "$CONFIG_FILE" <<'JSON'
{
  "account": "iCloud",
  "company_folder": "Firma",
  "default_image_dir": "/tmp/apple-notes-images"
}
JSON
[ -f "$MAPPING_FILE" ] || echo '{}' > "$MAPPING_FILE"

ACCOUNT="$(python3 -c "import json;print(json.load(open('$CONFIG_FILE')).get('account','iCloud'))")"
COMPANY="$(python3 -c "import json;print(json.load(open('$CONFIG_FILE')).get('company_folder','Firma'))")"
DEFAULT_IMG_DIR="$(python3 -c "import json;print(json.load(open('$CONFIG_FILE')).get('default_image_dir','/tmp/apple-notes-images'))")"

die() { echo "Error: $*" >&2; exit 1; }
need() { [ -n "${1:-}" ] || die "missing argument: $2"; }

# Run AppleScript from stdin with positional args via argv.
osa() { /usr/bin/osascript - "$@"; }

# Format ISO date from AppleScript date string (locale-agnostic).
iso_date() { python3 -c "
import sys, datetime
for line in sys.stdin:
    ts = line.strip()
    if not ts: continue
    try:
        # ts is epoch seconds (we set it in AppleScript)
        print(datetime.datetime.fromtimestamp(int(ts)).strftime('%Y-%m-%d'))
    except Exception:
        print(ts)
"; }

# ───── projects ─────────────────────────────────────────────────────────
cmd_projects() {
  local json=0
  [ "${1:-}" = "--json" ] && json=1
  local out
  out="$(osa "$ACCOUNT" "$COMPANY" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set output to ""
  tell application "Notes"
    try
      set parentFolder to folder parentName of account acct
    on error errMsg
      return "ERR:" & errMsg
    end try
    set subs to folders of parentFolder
    repeat with sf in subs
      set sName to name of sf
      set nCount to (count of notes of sf)
      set output to output & sName & tab & nCount & linefeed
    end repeat
  end tell
  return output
end run
APPLESCRIPT
)"
  case "$out" in
    ERR:*) die "${out#ERR:}" ;;
  esac
  if [ "$json" = 1 ]; then
    printf '%s' "$out" | python3 -c "
import sys, json
rows=[]
for line in sys.stdin:
    line=line.rstrip()
    if not line: continue
    name,count=line.split('\t')
    rows.append({'name':name,'notes':int(count)})
print(json.dumps(rows, ensure_ascii=False, indent=2))
"
  else
    printf '%s' "$out" | awk -F'\t' 'NF==2 {printf "%-30s %s notes\n", $1, $2}'
  fi
}

# ───── resolve ──────────────────────────────────────────────────────────
cmd_resolve() {
  local repo="${1:-}"
  if [ -z "$repo" ]; then
    repo="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null | xargs -I{} basename {} 2>/dev/null || true)"
    [ -z "$repo" ] && repo="$(basename "$PWD")"
  fi
  local key
  key="$(echo "$repo" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9')"
  [ -n "$key" ] || die "could not derive a project key from '$repo'"

  # Cache hit?
  local cached
  cached="$(python3 -c "
import json
m=json.load(open('$MAPPING_FILE'))
print(m.get('$key',''))
")"
  if [ -n "$cached" ]; then
    echo "$cached"; return 0
  fi

  # Fuzzy match against subfolders
  local subfolders match
  subfolders="$(cmd_projects | awk '{print $1}')"
  match="$(printf '%s\n' "$subfolders" | python3 -c "
import sys, difflib
key='$key'
candidates=[l.strip() for l in sys.stdin if l.strip()]
# 1) exact lowercase match
exact=[c for c in candidates if c.lower()==key]
if exact: print(exact[0]); sys.exit(0)
# 2) substring (key in candidate or candidate in key)
sub=[c for c in candidates if key in c.lower() or c.lower() in key]
if len(sub)==1: print(sub[0]); sys.exit(0)
if len(sub)>1:
    sys.stderr.write('AMBIGUOUS: '+', '.join(sub)+'\n'); sys.exit(2)
# 3) difflib best
best=difflib.get_close_matches(key,[c.lower() for c in candidates],n=1,cutoff=0.6)
if best:
    for c in candidates:
        if c.lower()==best[0]: print(c); sys.exit(0)
sys.stderr.write('NOMATCH\n'); sys.exit(3)
")" || {
    local rc=$?
    echo "Available projects:" >&2
    printf '  %s\n' $subfolders >&2
    echo "" >&2
    if [ "$rc" = 2 ]; then
      die "ambiguous match for '$repo'. Set explicitly: apple-notes config set-mapping $key <ProjectName>"
    else
      die "no project matches '$repo'. Set explicitly: apple-notes config set-mapping $key <ProjectName>"
    fi
  }
  # Cache and return
  python3 -c "
import json
m=json.load(open('$MAPPING_FILE'))
m['$key']='$match'
json.dump(m, open('$MAPPING_FILE','w'), indent=2, ensure_ascii=False)
"
  echo "$match"
}

# ───── notes ────────────────────────────────────────────────────────────
cmd_notes() {
  local project="${1:-}"; need "$project" "<project>"; shift
  local limit=0 preview=80 json=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --limit) limit="$2"; shift 2 ;;
      --preview) preview="$2"; shift 2 ;;
      --json) json=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local out
  out="$(osa "$ACCOUNT" "$COMPANY" "$project" "$limit" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set sub to item 3 of argv
  set lim to (item 4 of argv) as integer
  set output to ""
  tell application "Notes"
    try
      set theFolder to folder sub of folder parentName of account acct
    on error errMsg
      return "ERR:" & errMsg
    end try
    set theNotes to notes of theFolder
    set idx to 0
    repeat with n in theNotes
      set idx to idx + 1
      if lim > 0 and idx > lim then exit repeat
      set nName to name of n
      set modDate to modification date of n
      set firstPart to plaintext of n
      if (count of firstPart) > 400 then set firstPart to (text 1 thru 400 of firstPart)
      set firstPart to my squash(firstPart)
      set output to output & nName & tab & my isoDate(modDate) & tab & firstPart & linefeed
    end repeat
  end tell
  return output
end run

on isoDate(d)
  set y to (year of d) as text
  set m to (month of d) as integer
  set dd to (day of d) as integer
  set mPad to text -2 thru -1 of ("0" & m)
  set dPad to text -2 thru -1 of ("0" & dd)
  return y & "-" & mPad & "-" & dPad
end isoDate

on squash(t)
  set text item delimiters of AppleScript to {linefeed, return, tab}
  set parts to text items of t
  set text item delimiters of AppleScript to " "
  set t2 to parts as text
  set text item delimiters of AppleScript to ""
  return t2
end squash
APPLESCRIPT
)"
  case "$out" in
    ERR:*) die "${out#ERR:}" ;;
  esac

  printf '%s' "$out" | python3 -c "
import sys, json
rows=[]
preview=$preview
for line in sys.stdin:
    line=line.rstrip('\n')
    if not line: continue
    parts=line.split('\t', 2)
    if len(parts)<3: continue
    title, date, body = parts
    rows.append({'title':title,'modified':date,'preview':body[:preview]})

if $json:
    print(json.dumps(rows, ensure_ascii=False, indent=2))
else:
    for r in rows:
        print(f\"{r['modified']}  {r['title'][:50]:<50}  {r['preview']}\")
"
}

# ───── get ──────────────────────────────────────────────────────────────
cmd_get() {
  local project="${1:-}"; need "$project" "<project>"
  local title="${2:-}"; need "$title" "<title>"
  shift 2
  local format=text
  while [ $# -gt 0 ]; do
    case "$1" in
      --format) format="$2"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local out
  out="$(osa "$ACCOUNT" "$COMPANY" "$project" "$title" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set sub to item 3 of argv
  set t to item 4 of argv
  tell application "Notes"
    try
      set theFolder to folder sub of folder parentName of account acct
    on error errMsg
      return "ERR:" & errMsg
    end try
    set matches to (notes of theFolder whose name is t)
    if (count of matches) = 0 then return "ERR:note not found: " & t
    set theNote to item 1 of matches
    return body of theNote
  end tell
end run
APPLESCRIPT
)"
  case "$out" in
    ERR:*) die "${out#ERR:}" ;;
  esac

  case "$format" in
    text) printf '%s' "$out" | python3 "$HELPER" to-text ;;
    html) printf '%s' "$out" | python3 "$HELPER" strip-base64 ;;
    raw)  printf '%s\n' "$out" ;;
    *) die "unknown --format: $format (use text|html|raw)" ;;
  esac
}

# ───── images ───────────────────────────────────────────────────────────
cmd_images() {
  local project="${1:-}"; need "$project" "<project>"
  local title="${2:-}"; need "$title" "<title>"
  shift 2
  local out_dir="$DEFAULT_IMG_DIR"
  while [ $# -gt 0 ]; do
    case "$1" in
      --out) out_dir="$2"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  # Slug for subdir
  local slug
  slug="$(echo "${project}_${title}" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//' | cut -c1-60)"
  local target="$out_dir/$slug"
  mkdir -p "$target"

  local body
  body="$(osa "$ACCOUNT" "$COMPANY" "$project" "$title" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set sub to item 3 of argv
  set t to item 4 of argv
  tell application "Notes"
    try
      set theFolder to folder sub of folder parentName of account acct
    on error errMsg
      return "ERR:" & errMsg
    end try
    set matches to (notes of theFolder whose name is t)
    if (count of matches) = 0 then return "ERR:note not found: " & t
    return body of (item 1 of matches)
  end tell
end run
APPLESCRIPT
)"
  case "$body" in
    ERR:*) die "${body#ERR:}" ;;
  esac
  printf '%s' "$body" | python3 "$HELPER" extract-images "$target"
}

# ───── search ───────────────────────────────────────────────────────────
cmd_search() {
  local query="${1:-}"; need "$query" "<query>"; shift
  local project="" json=0 preview=80
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --json) json=1; shift ;;
      --preview) preview="$2"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local out
  out="$(osa "$ACCOUNT" "$COMPANY" "$query" "$project" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set q to item 3 of argv
  set onlyProject to item 4 of argv
  set output to ""
  tell application "Notes"
    try
      set parentFolder to folder parentName of account acct
    on error errMsg
      return "ERR:" & errMsg
    end try
    if onlyProject is "" then
      set subs to folders of parentFolder
    else
      set subs to {folder onlyProject of parentFolder}
    end if
    repeat with sf in subs
      set sName to name of sf
      set hits to (notes of sf whose name contains q or plaintext contains q)
      repeat with n in hits
        set modDate to modification date of n
        set firstPart to plaintext of n
        if (count of firstPart) > 400 then set firstPart to (text 1 thru 400 of firstPart)
        set firstPart to my squash(firstPart)
        set output to output & sName & tab & (name of n) & tab & my isoDate(modDate) & tab & firstPart & linefeed
      end repeat
    end repeat
  end tell
  return output
end run

on isoDate(d)
  set y to (year of d) as text
  set m to (month of d) as integer
  set dd to (day of d) as integer
  set mPad to text -2 thru -1 of ("0" & m)
  set dPad to text -2 thru -1 of ("0" & dd)
  return y & "-" & mPad & "-" & dPad
end isoDate

on squash(t)
  set text item delimiters of AppleScript to {linefeed, return, tab}
  set parts to text items of t
  set text item delimiters of AppleScript to " "
  set t2 to parts as text
  set text item delimiters of AppleScript to ""
  return t2
end squash
APPLESCRIPT
)"
  case "$out" in
    ERR:*) die "${out#ERR:}" ;;
  esac

  printf '%s' "$out" | python3 -c "
import sys, json
rows=[]
preview=$preview
for line in sys.stdin:
    line=line.rstrip('\n')
    if not line: continue
    parts=line.split('\t', 3)
    if len(parts)<4: continue
    proj, title, date, body = parts
    rows.append({'project':proj,'title':title,'modified':date,'preview':body[:preview]})
rows.sort(key=lambda r:r['modified'], reverse=True)

if $json:
    print(json.dumps(rows, ensure_ascii=False, indent=2))
else:
    for r in rows:
        print(f\"{r['modified']}  {r['project'][:15]:<15}  {r['title'][:40]:<40}  {r['preview']}\")
"
}

# ───── create / update / append ─────────────────────────────────────────
read_body() {
  local body_file=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --body-file) body_file="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [ -n "$body_file" ]; then
    cat "$body_file"
  elif [ -t 0 ]; then
    die "no body provided. Pipe content via stdin or use --body-file"
  else
    cat
  fi
}

cmd_create() {
  local project="${1:-}"; need "$project" "<project>"
  local title="${2:-}"; need "$title" "<title>"
  shift 2
  local body
  body="$(read_body "$@")"
  # Wrap plain text in <div> if it doesn't already contain HTML
  if ! printf '%s' "$body" | grep -q '<'; then
    body="$(printf '%s' "$body" | python3 -c "
import sys, html
lines=sys.stdin.read().splitlines() or ['']
print(''.join('<div>'+html.escape(l or '<br>')+'</div>' for l in lines))
")"
  fi
  osa "$ACCOUNT" "$COMPANY" "$project" "$title" "$body" <<'APPLESCRIPT' >/dev/null
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set sub to item 3 of argv
  set t to item 4 of argv
  set b to item 5 of argv
  tell application "Notes"
    set theFolder to folder sub of folder parentName of account acct
    make new note at theFolder with properties {body:"<div>" & t & "</div>" & b}
  end tell
end run
APPLESCRIPT
  echo "created: $title in $project"
}

cmd_update() {
  local project="${1:-}"; need "$project" "<project>"
  local title="${2:-}"; need "$title" "<title>"
  shift 2
  local body
  body="$(read_body "$@")"
  if ! printf '%s' "$body" | grep -q '<'; then
    body="$(printf '%s' "$body" | python3 -c "
import sys, html
lines=sys.stdin.read().splitlines() or ['']
print(''.join('<div>'+html.escape(l or '<br>')+'</div>' for l in lines))
")"
  fi
  local out
  out="$(osa "$ACCOUNT" "$COMPANY" "$project" "$title" "$body" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set sub to item 3 of argv
  set t to item 4 of argv
  set b to item 5 of argv
  tell application "Notes"
    set theFolder to folder sub of folder parentName of account acct
    set matches to (notes of theFolder whose name is t)
    if (count of matches) = 0 then return "ERR:note not found: " & t
    set body of (item 1 of matches) to "<div>" & t & "</div>" & b
  end tell
  return "OK"
end run
APPLESCRIPT
)"
  case "$out" in ERR:*) die "${out#ERR:}";; esac
  echo "updated: $title in $project"
}

cmd_append() {
  local project="${1:-}"; need "$project" "<project>"
  local title="${2:-}"; need "$title" "<title>"
  shift 2
  local body
  body="$(read_body "$@")"
  if ! printf '%s' "$body" | grep -q '<'; then
    body="$(printf '%s' "$body" | python3 -c "
import sys, html
lines=sys.stdin.read().splitlines() or ['']
print(''.join('<div>'+html.escape(l or '<br>')+'</div>' for l in lines))
")"
  fi
  local out
  out="$(osa "$ACCOUNT" "$COMPANY" "$project" "$title" "$body" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set sub to item 3 of argv
  set t to item 4 of argv
  set b to item 5 of argv
  tell application "Notes"
    set theFolder to folder sub of folder parentName of account acct
    set matches to (notes of theFolder whose name is t)
    if (count of matches) = 0 then return "ERR:note not found: " & t
    set theNote to item 1 of matches
    set existing to body of theNote
    set body of theNote to existing & b
  end tell
  return "OK"
end run
APPLESCRIPT
)"
  case "$out" in ERR:*) die "${out#ERR:}";; esac
  echo "appended to: $title in $project"
}

# ───── delete / move ────────────────────────────────────────────────────
cmd_delete() {
  local project="${1:-}"; need "$project" "<project>"
  local title="${2:-}"; need "$title" "<title>"
  shift 2
  local force=0
  [ "${1:-}" = "--force" ] && force=1
  if [ "$force" = 0 ]; then
    echo "About to delete '$title' in '$project'. Re-run with --force to confirm." >&2
    exit 1
  fi
  local out
  out="$(osa "$ACCOUNT" "$COMPANY" "$project" "$title" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set sub to item 3 of argv
  set t to item 4 of argv
  tell application "Notes"
    set theFolder to folder sub of folder parentName of account acct
    set matches to (notes of theFolder whose name is t)
    if (count of matches) = 0 then return "ERR:note not found: " & t
    delete (item 1 of matches)
  end tell
  return "OK"
end run
APPLESCRIPT
)"
  case "$out" in ERR:*) die "${out#ERR:}";; esac
  echo "deleted: $title from $project (moved to Recently Deleted)"
}

cmd_move() {
  local from="${1:-}"; need "$from" "<from-project>"
  local title="${2:-}"; need "$title" "<title>"
  local to="${3:-}"; need "$to" "<to-project>"
  local out
  out="$(osa "$ACCOUNT" "$COMPANY" "$from" "$title" "$to" <<'APPLESCRIPT'
on run argv
  set acct to item 1 of argv
  set parentName to item 2 of argv
  set fromSub to item 3 of argv
  set t to item 4 of argv
  set toSub to item 5 of argv
  tell application "Notes"
    set fromFolder to folder fromSub of folder parentName of account acct
    set toFolder to folder toSub of folder parentName of account acct
    set matches to (notes of fromFolder whose name is t)
    if (count of matches) = 0 then return "ERR:note not found: " & t
    move (item 1 of matches) to toFolder
  end tell
  return "OK"
end run
APPLESCRIPT
)"
  case "$out" in ERR:*) die "${out#ERR:}";; esac
  echo "moved: $title from $from to $to"
}

# ───── config ───────────────────────────────────────────────────────────
cmd_config() {
  local sub="${1:-}"
  case "$sub" in
    show)
      echo "config:  $CONFIG_FILE"
      cat "$CONFIG_FILE"
      echo ""
      echo "mapping: $MAPPING_FILE"
      cat "$MAPPING_FILE"
      ;;
    set-mapping)
      local key="${2:-}"; need "$key" "<repo-key>"
      local val="${3:-}"; need "$val" "<project-name>"
      key="$(echo "$key" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9')"
      python3 -c "
import json
m=json.load(open('$MAPPING_FILE'))
m['$key']='$val'
json.dump(m, open('$MAPPING_FILE','w'), indent=2, ensure_ascii=False)
print(f'mapped {repr(\"$key\")} -> {repr(\"$val\")}')
"
      ;;
    set)
      local key="${2:-}"; need "$key" "<key>"
      local val="${3:-}"; need "$val" "<value>"
      python3 -c "
import json
c=json.load(open('$CONFIG_FILE'))
c['$key']='$val'
json.dump(c, open('$CONFIG_FILE','w'), indent=2, ensure_ascii=False)
print(f'set {repr(\"$key\")} = {repr(\"$val\")}')
"
      ;;
    *) die "config subcommands: show | set <key> <value> | set-mapping <repo> <project>" ;;
  esac
}

# ───── usage ────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
apple-notes — Apple Notes access for Claude Code

Usage:
  apple-notes projects [--json]
  apple-notes resolve [REPO]
  apple-notes notes <PROJECT> [--limit N] [--preview N] [--json]
  apple-notes get <PROJECT> <TITLE> [--format text|html|raw]
  apple-notes images <PROJECT> <TITLE> [--out DIR]
  apple-notes search <QUERY> [--project NAME] [--json] [--preview N]
  apple-notes create <PROJECT> <TITLE> [--body-file FILE]   (body on stdin)
  apple-notes update <PROJECT> <TITLE> [--body-file FILE]   (body on stdin)
  apple-notes append <PROJECT> <TITLE> [--body-file FILE]   (body on stdin)
  apple-notes delete <PROJECT> <TITLE> --force
  apple-notes move <FROM_PROJECT> <TITLE> <TO_PROJECT>
  apple-notes config show
  apple-notes config set <key> <value>
  apple-notes config set-mapping <repo-key> <project-name>

Config: $CONFIG_FILE
Mapping: $MAPPING_FILE
EOF
}

# ───── dispatcher ───────────────────────────────────────────────────────
cmd="${1:-}"
shift || true
case "$cmd" in
  projects) cmd_projects "$@" ;;
  resolve)  cmd_resolve "$@" ;;
  notes)    cmd_notes "$@" ;;
  get)      cmd_get "$@" ;;
  images)   cmd_images "$@" ;;
  search)   cmd_search "$@" ;;
  create)   cmd_create "$@" ;;
  update)   cmd_update "$@" ;;
  append)   cmd_append "$@" ;;
  delete)   cmd_delete "$@" ;;
  move)     cmd_move "$@" ;;
  config)   cmd_config "$@" ;;
  -h|--help|help|"") usage ;;
  *) usage; die "unknown command: $cmd" ;;
esac
