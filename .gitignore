# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Node (in case any skill ever ships JS tooling)
node_modules/

# Python bytecode (from running tests in tests/)
__pycache__/
*.py[cod]

# Local scratch
.scratch/

# Claude Code local-only settings (per-project; never shared)
.claude/settings.local.json

# Skill secrets — API keys live in <skill>/.env and must NEVER be committed.
# (e.g. skills/openai-image/.env). .env.example stays tracked as the schema.
.env
**/.env
!**/.env.example
